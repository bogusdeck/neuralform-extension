<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add User Profile - AutoFill Pro</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            padding: 40px 20px;
        }

        .container {
            max-width: 700px;
            margin: 0 auto;
            background: white;
            padding: 40px;
            border-radius: 12px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
        }

        h1 {
            color: #333;
            margin-bottom: 10px;
            text-align: center;
        }

        .subtitle {
            text-align: center;
            color: #666;
            margin-bottom: 30px;
        }

        .section {
            margin-bottom: 30px;
        }

        .section h2 {
            color: #667eea;
            font-size: 18px;
            margin-bottom: 15px;
            padding-bottom: 10px;
            border-bottom: 2px solid #f0f0f0;
        }

        .form-group {
            margin-bottom: 20px;
        }

        label {
            display: block;
            margin-bottom: 5px;
            color: #333;
            font-weight: 500;
            font-size: 14px;
        }

        input, select {
            width: 100%;
            padding: 12px;
            border: 2px solid #e0e0e0;
            border-radius: 6px;
            font-size: 14px;
            transition: border-color 0.3s;
        }

        input:focus, select:focus {
            outline: none;
            border-color: #667eea;
        }

        .row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 15px;
        }

        button {
            width: 100%;
            padding: 15px;
            background: #667eea;
            color: white;
            border: none;
            border-radius: 6px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: background 0.3s;
            margin-bottom: 10px;
        }

        button:hover {
            background: #5568d3;
        }

        button.secondary {
            background: #6c757d;
        }

        button.secondary:hover {
            background: #5a6268;
        }

        button.danger {
            background: #f56565;
        }

        button.danger:hover {
            background: #e53e3e;
        }

        .status {
            padding: 15px;
            margin: 20px 0;
            border-radius: 6px;
            font-weight: 500;
            display: none;
        }

        .success {
            background: #d4edda;
            color: #155724;
            border: 1px solid #c3e6cb;
            display: block;
        }

        .error {
            background: #f8d7da;
            color: #721c24;
            border: 1px solid #f5c6cb;
            display: block;
        }

        .info {
            background: #d1ecf1;
            color: #0c5460;
            border: 1px solid #bee5eb;
            display: block;
        }

        .user-id {
            background: #f8f9fa;
            padding: 10px;
            border-radius: 4px;
            margin-bottom: 20px;
            font-family: monospace;
            font-size: 12px;
            word-break: break-all;
        }

        .current-data {
            background: #f8f9fa;
            padding: 20px;
            border-radius: 6px;
            margin-bottom: 20px;
            display: none;
        }

        .current-data h3 {
            margin-bottom: 15px;
            color: #667eea;
        }

        .data-item {
            margin-bottom: 8px;
            font-size: 14px;
        }

        .data-item strong {
            color: #333;
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>Add User Profile</h1>
        <p class="subtitle">Add or update your profile data in Supabase</p>

        <div class="user-id">
            <strong>Your User ID:</strong> <span id="userId">Generating...</span>
        </div>

        <div class="status" id="status"></div>

        <div class="current-data" id="currentData">
            <h3>Current Profile Data:</h3>
            <div id="dataDisplay"></div>
        </div>

        <form id="profileForm">
            <div class="section">
                <h2>Personal Information</h2>

                <div class="row">
                    <div class="form-group">
                        <label for="firstName">First Name</label>
                        <input type="text" id="firstName" placeholder="John">
                    </div>

                    <div class="form-group">
                        <label for="lastName">Last Name</label>
                        <input type="text" id="lastName" placeholder="Doe">
                    </div>
                </div>

                <div class="form-group">
                    <label for="fullName">Full Name</label>
                    <input type="text" id="fullName" placeholder="John Doe">
                </div>

                <div class="row">
                    <div class="form-group">
                        <label for="dob">Date of Birth</label>
                        <input type="date" id="dob">
                    </div>

                    <div class="form-group">
                        <label for="gender">Gender</label>
                        <select id="gender">
                            <option value="">Select...</option>
                            <option value="male">Male</option>
                            <option value="female">Female</option>
                            <option value="other">Other</option>
                        </select>
                    </div>
                </div>
            </div>

            <div class="section">
                <h2>Government Exam Details</h2>

                <div class="row">
                    <div class="form-group">
                        <label for="category">Category/Caste</label>
                        <select id="category">
                            <option value="">Select...</option>
                            <option value="general">General</option>
                            <option value="obc">OBC</option>
                            <option value="sc">SC</option>
                            <option value="st">ST</option>
                            <option value="ews">EWS</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label for="nationality">Nationality</label>
                        <input type="text" id="nationality" placeholder="Indian">
                    </div>
                </div>

                <div class="row">
                    <div class="form-group">
                        <label for="fatherName">Father's Name</label>
                        <input type="text" id="fatherName" placeholder="Father's Name">
                    </div>

                    <div class="form-group">
                        <label for="motherName">Mother's Name</label>
                        <input type="text" id="motherName" placeholder="Mother's Name">
                    </div>
                </div>
            </div>

            <div class="section">
                <h2>Contact Information</h2>

                <div class="form-group">
                    <label for="email">Email Address</label>
                    <input type="email" id="email" placeholder="your@email.com">
                </div>

                <div class="row">
                    <div class="form-group">
                        <label for="phone">Phone Number</label>
                        <input type="tel" id="phone" placeholder="+1 234 567 8900">
                    </div>

                    <div class="form-group">
                        <label for="alternatePhone">Alternate Phone</label>
                        <input type="tel" id="alternatePhone" placeholder="+1 234 567 8901">
                    </div>
                </div>
            </div>

            <div class="section">
                <h2>Address</h2>

                <div class="form-group">
                    <label for="address">Permanent Address</label>
                    <input type="text" id="address" placeholder="123 Main Street">
                </div>

                <div class="form-group">
                    <label for="address2">Current Address (if different)</label>
                    <input type="text" id="address2" placeholder="Apt 4B, Suite 100">
                </div>

                <div class="row">
                    <div class="form-group">
                        <label for="city">City</label>
                        <input type="text" id="city" placeholder="New York">
                    </div>

                    <div class="form-group">
                        <label for="state">State/District</label>
                        <input type="text" id="state" placeholder="NY">
                    </div>
                </div>

                <div class="row">
                    <div class="form-group">
                        <label for="zipCode">ZIP Code</label>
                        <input type="text" id="zipCode" placeholder="10001">
                    </div>

                    <div class="form-group">
                        <label for="country">Country</label>
                        <input type="text" id="country" placeholder="United States">
                    </div>
                </div>
            </div>

            <div class="section">
                <h2>Educational Qualifications</h2>

                <div class="form-group">
                    <label for="degree">Degree/Certificate</label>
                    <input type="text" id="degree" placeholder="B.Tech, B.Com, etc.">
                </div>

                <div class="form-group">
                    <label for="institution">Institution/University</label>
                    <input type="text" id="institution" placeholder="Institution Name">
                </div>

                <div class="row">
                    <div class="form-group">
                        <label for="yearOfPassing">Year of Passing</label>
                        <input type="text" id="yearOfPassing" placeholder="2023">
                    </div>

                    <div class="form-group">
                        <label for="percentageCgpa">Percentage/CGPA</label>
                        <input type="text" id="percentageCgpa" placeholder="85.5 or 8.5 CGPA">
                    </div>
                </div>

                <div class="form-group">
                    <label for="boardUniversity">Board/University</label>
                    <input type="text" id="boardUniversity" placeholder="Board or University Name">
                </div>
            </div>

            <div class="section">
                <h2>Exam Details</h2>

                <div class="form-group">
                    <label for="preferredCenter">Preferred Exam Center</label>
                    <input type="text" id="preferredCenter" placeholder="City/Center Name">
                </div>

                <div class="form-group">
                    <label for="subjectPreference">Subject/Paper Preference</label>
                    <input type="text" id="subjectPreference" placeholder="Subject Name">
                </div>

                <div class="row">
                    <div class="form-group">
                        <label for="languagePreference">Language Preference</label>
                        <select id="languagePreference">
                            <option value="">Select...</option>
                            <option value="english">English</option>
                            <option value="hindi">Hindi</option>
                            <option value="regional">Regional Language</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label for="idProofType">ID Proof Type</label>
                        <select id="idProofType">
                            <option value="">Select...</option>
                            <option value="aadhaar">Aadhaar Card</option>
                            <option value="pan">PAN Card</option>
                            <option value="voter">Voter ID</option>
                            <option value="passport">Passport</option>
                            <option value="driving">Driving License</option>
                        </select>
                    </div>
                </div>

                <div class="form-group">
                    <label for="idNumber">ID Number</label>
                    <input type="text" id="idNumber" placeholder="ID Document Number">
                </div>

                <div class="row">
                    <div class="form-group">
                        <label for="disabilityStatus">Disability Status</label>
                        <select id="disabilityStatus">
                            <option value="">Select...</option>
                            <option value="none">None</option>
                            <option value="yes">Yes (Specify in remarks)</option>
                        </select>
                    </div>

                    <div class="form-group">
                        <label for="workExperience">Work Experience</label>
                        <input type="text" id="workExperience" placeholder="Years/Details">
                    </div>
                </div>
            </div>

            <button type="submit">Save Profile to Supabase</button>
            <button type="button" class="secondary" onclick="loadCurrentData()">Load Current Profile</button>
            <button type="button" class="danger" onclick="clearProfile()">Clear Profile</button>
        </form>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
    <script>
        const SUPABASE_URL = 'https://htekvelkwfqgfrtpiivp.supabase.co';
        const SUPABASE_ANON_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Imh0ZWt2ZWxrd2ZxZ2ZydHBpaXZwIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzYxODM2MzcsImV4cCI6MjA5MTc1OTYzN30.J1BT9lSuAYwf5S6RefRg9ykgzxRS7sFnWD7aNWLHaUU';

        const supabase = supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY);

        let userId = localStorage.getItem('autofill_user_id');

        if (!userId) {
            userId = crypto.randomUUID();
            localStorage.setItem('autofill_user_id', userId);
        }

        document.getElementById('userId').textContent = userId;

        async function saveProfile(e) {
            e.preventDefault();

            const data = {
                user_id: userId,
                first_name: document.getElementById('firstName').value || null,
                last_name: document.getElementById('lastName').value || null,
                full_name: document.getElementById('fullName').value || null,
                email: document.getElementById('email').value || null,
                phone: document.getElementById('phone').value || null,
                alternate_phone: document.getElementById('alternatePhone').value || null,
                address: document.getElementById('address').value || null,
                address2: document.getElementById('address2').value || null,
                city: document.getElementById('city').value || null,
                state: document.getElementById('state').value || null,
                zip_code: document.getElementById('zipCode').value || null,
                country: document.getElementById('country').value || null,
                dob: document.getElementById('dob').value || null,
                gender: document.getElementById('gender').value || null,
                category: document.getElementById('category').value || null,
                nationality: document.getElementById('nationality').value || null,
                father_name: document.getElementById('fatherName').value || null,
                mother_name: document.getElementById('motherName').value || null,
                degree: document.getElementById('degree').value || null,
                institution: document.getElementById('institution').value || null,
                year_of_passing: document.getElementById('yearOfPassing').value || null,
                percentage_cgpa: document.getElementById('percentageCgpa').value || null,
                board_university: document.getElementById('boardUniversity').value || null,
                preferred_center: document.getElementById('preferredCenter').value || null,
                subject_preference: document.getElementById('subjectPreference').value || null,
                language_preference: document.getElementById('languagePreference').value || null,
                id_proof_type: document.getElementById('idProofType').value || null,
                id_number: document.getElementById('idNumber').value || null,
                disability_status: document.getElementById('disabilityStatus').value || null,
                work_experience: document.getElementById('workExperience').value || null,
                updated_at: new Date().toISOString()
            };

            showStatus('Saving profile...', 'info');

            try {
                const { data: result, error } = await supabase
                    .from('user_profiles')
                    .upsert(data, { onConflict: 'user_id' })
                    .select();

                if (error) throw error;

                showStatus('✅ Profile saved successfully to Supabase!', 'success');
                console.log('Saved:', result);
            } catch (error) {
                showStatus('❌ Error saving profile: ' + error.message, 'error');
                console.error('Error:', error);
            }
        }

        async function loadCurrentData() {
            showStatus('Loading current profile...', 'info');

            try {
                const { data, error } = await supabase
                    .from('user_profiles')
                    .select('*')
                    .eq('user_id', userId)
                    .single();

                if (error) {
                    if (error.code === 'PGRST116') {
                        showStatus('No existing profile found. Please fill in the form.', 'info');
                        return;
                    }
                    throw error;
                }

                if (data) {
                    document.getElementById('firstName').value = data.first_name || '';
                    document.getElementById('lastName').value = data.last_name || '';
                    document.getElementById('fullName').value = data.full_name || '';
                    document.getElementById('email').value = data.email || '';
                    document.getElementById('phone').value = data.phone || '';
                    document.getElementById('alternatePhone').value = data.alternate_phone || '';
                    document.getElementById('address').value = data.address || '';
                    document.getElementById('address2').value = data.address2 || '';
                    document.getElementById('city').value = data.city || '';
                    document.getElementById('state').value = data.state || '';
                    document.getElementById('zipCode').value = data.zip_code || '';
                    document.getElementById('country').value = data.country || '';
                    document.getElementById('dob').value = data.dob || '';
                    document.getElementById('gender').value = data.gender || '';
                    document.getElementById('category').value = data.category || '';
                    document.getElementById('nationality').value = data.nationality || '';
                    document.getElementById('fatherName').value = data.father_name || '';
                    document.getElementById('motherName').value = data.mother_name || '';
                    document.getElementById('degree').value = data.degree || '';
                    document.getElementById('institution').value = data.institution || '';
                    document.getElementById('yearOfPassing').value = data.year_of_passing || '';
                    document.getElementById('percentageCgpa').value = data.percentage_cgpa || '';
                    document.getElementById('boardUniversity').value = data.board_university || '';
                    document.getElementById('preferredCenter').value = data.preferred_center || '';
                    document.getElementById('subjectPreference').value = data.subject_preference || '';
                    document.getElementById('languagePreference').value = data.language_preference || '';
                    document.getElementById('idProofType').value = data.id_proof_type || '';
                    document.getElementById('idNumber').value = data.id_number || '';
                    document.getElementById('disabilityStatus').value = data.disability_status || '';
                    document.getElementById('workExperience').value = data.work_experience || '';

                    displayCurrentData(data);
                    showStatus('✅ Profile loaded successfully!', 'success');
                }
            } catch (error) {
                showStatus('❌ Error loading profile: ' + error.message, 'error');
                console.error('Error:', error);
            }
        }

        async function clearProfile() {
            if (!confirm('Are you sure you want to delete your profile from Supabase?')) {
                return;
            }

            showStatus('Deleting profile...', 'info');

            try {
                const { error } = await supabase
                    .from('user_profiles')
                    .delete()
                    .eq('user_id', userId);

                if (error) throw error;

                document.getElementById('profileForm').reset();
                document.getElementById('currentData').style.display = 'none';
                showStatus('✅ Profile deleted successfully!', 'success');
            } catch (error) {
                showStatus('❌ Error deleting profile: ' + error.message, 'error');
                console.error('Error:', error);
            }
        }

        function displayCurrentData(data) {
            const display = document.getElementById('dataDisplay');
            display.innerHTML = `
                <div class="data-item"><strong>Full Name:</strong> ${data.full_name || 'N/A'}</div>
                <div class="data-item"><strong>Email:</strong> ${data.email || 'N/A'}</div>
                <div class="data-item"><strong>Phone:</strong> ${data.phone || 'N/A'}</div>
                <div class="data-item"><strong>City:</strong> ${data.city || 'N/A'}</div>
                <div class="data-item"><strong>Country:</strong> ${data.country || 'N/A'}</div>
                <div class="data-item"><strong>Last Updated:</strong> ${new Date(data.updated_at).toLocaleString()}</div>
            `;
            document.getElementById('currentData').style.display = 'block';
        }

        function showStatus(message, type) {
            const statusEl = document.getElementById('status');
            statusEl.textContent = message;
            statusEl.className = 'status ' + type;

            setTimeout(() => {
                statusEl.textContent = '';
                statusEl.className = 'status';
            }, 5000);
        }

        document.getElementById('profileForm').addEventListener('submit', saveProfile);

        window.onload = function() {
            loadCurrentData();
        };
    </script>
</body>
</html>
